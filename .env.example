APP_NAME=SHAE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# En production (Render) : https://votre-app.onrender.com
# APP_FORCE_HTTPS=true

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shae
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@shae.com"
MAIL_FROM_NAME="${APP_NAME}"

LABPAY_API_URL=https://api.labyrinthe-rdc.com
# Token LabPay : copier storage/app/labpay-api-token.example.txt vers labpay-api-token.txt
LABPAY_API_KEY=
LABPAY_CURRENCY=USD
LABPAY_COUNTRY=CD
# En production Render : https://votre-app.onrender.com/payments/callback
# Token : storage/app/labpay-api-token.txt (local) ou LABPAY_API_KEY (Render)
LABPAY_CALLBACK_URL="${APP_URL}/payments/callback"

OTP_EXPIRATION_MINUTES=10

VITE_APP_NAME="${APP_NAME}"
